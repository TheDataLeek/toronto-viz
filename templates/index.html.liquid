<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TTC Vehicle Tracker</title>
    <link rel="stylesheet" href="./styles.css">
</head>
<body>
    <header>
        <span class="header-brand">TTC Tracker</span>
        <input type="checkbox" id="nav-toggle" class="nav-toggle-input">
        <label class="hamburger" for="nav-toggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </label>
        <nav id="header-nav">
            <button class="nav-btn" id="btn-reset-map">Reset Map</button>
            <button class="nav-btn" id="btn-current-locations">Hide Locations</button>
            <button class="nav-btn" id="btn-avg-speeds">Average Speeds</button>
        </nav>
    </header>
    <div id="map">
        <span class="loader"></span>
    </div>
    <div id="colorbar"></div>
    <div id="status">Loading…</div>
    <div id="footer-links">
        <a href="https://dataleek.io/" target="_blank" rel="noopener">dataleek.io</a>
        <a href="https://github.com/TheDataLeek/toronto-viz" target="_blank" rel="noopener">source</a>
    </div>
    <script type="module">
        import { init } from '{{ script_src }}';
        init({ baseUrl: '{{ api_url }}' });
    </script>
</body>
</html>
