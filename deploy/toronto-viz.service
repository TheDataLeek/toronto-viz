[Unit]
Description=Toronto TTC Visualization
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/toronto-viz
ExecStart=/home/zoe/.local/bin/uv run python /opt/toronto-viz/main.py --host 0.0.0.0 --port 5000
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
