{
  "name": "toronto-viz",
  "version": "1.0.0",
  "description": "Scrapes TTC vehicle locations every 60 seconds and serves them via a Flask API. Designed to run on a Raspberry Pi as a systemd service.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build:css": "sass scss/main.scss dist/styles.css --no-source-map",
    "build": "npm run build:css && esbuild src/index.ts --bundle --minify --format=esm --outfile=dist/bundle.js",
    "typecheck": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheDataLeek/toronto-viz.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/TheDataLeek/toronto-viz/issues"
  },
  "homepage": "https://github.com/TheDataLeek/toronto-viz#readme",
  "dependencies": {
    "d3": "^7.9.0",
    "konva": "^10.2.5"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/geojson": "^7946.0.16",
    "esbuild": "^0.28.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.2"
  }
}
